# Neon Postgres connection string used for local development.
# In Vercel, set DATABASE_URL in the project's Environment Variables
# (Project Settings -> Environment Variables) using the pooled connection
# string from your Neon project dashboard.
#
# Local example (direct, non-pooled):
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?schema=public"

# Cloudinary image uploads.
# Copy this from Cloudinary Console -> Programmable Media -> API Keys.
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL="cloudinary://your-api-key:your-api-secret@your-cloud-name"
CLOUDINARY_UPLOAD_PRESET="game_portal"
CLOUDINARY_UPLOAD_FOLDER="region6-portal"

# Optional: upload seeded demo covers/artifacts to Cloudinary during npm run db:seed.
# Leave false for offline/local public assets.
CLOUDINARY_SEED_UPLOADS="false"
